msgid "### Stand proud, {}!\n_Through fire and thunder you prevailed,\nWhen others faltered, you stood strong,\nVictory is where you belong!_"
msgstr "### Гордитесь, {}!\n"
                        "_Сквозь огонь и гром ты победил,\n"
