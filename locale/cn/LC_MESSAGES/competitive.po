msgid "You won against {loser}! Your new rating is {rating}"
msgstr "您战胜了 {loser}！您的新评级为 {rating}"

msgid "You lost against {winner}! Your new rating is {rating}"
msgstr "您输给了 {winner}！您的新评级为 {rating}"

