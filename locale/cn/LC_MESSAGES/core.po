msgid "The server is full, please try again later."
msgstr "服务器已满，请稍后重试."

msgid "Your player name contains invalid characters. Please change your name to join our server."
msgstr "您的玩家名称包含无效字符。请修改名称后再加入服务器."

msgid "Please change your default player name at the top right of the multiplayer selection list to an individual one!"
msgstr "请将多人游戏服务器列表右上角的默认玩家名称改为一个个性化名称!"
