# /backup
msgid "Backup your data"
msgstr "Erstelle ein Backup"

msgid "Backup of {} started ..."
msgstr "Backup von {} gestartet ..."

msgid "Backup of {} completed."
msgstr "Backup von {} abgeschlossen."

msgid "Backup of {} failed. Please check log for details."
msgstr "Backup von {} fehlgeschlagen. Für Details, schaue bitte ins Logfile."

# /restore
msgid "Restore your data from an existing backup"
msgstr "Stelle Daten wieder her"

msgid "I am about to restore your {what} from {date}.\n"
"This action will completely overwrite any existing data.\n"
"Are you absolutely certain that you want to proceed?"
msgstr "Ich stelle jetzte das Backup zu {what} vom Datum {date} wieder her.\n"
"Das wird **ALLE** Deine Daten überschreiben.\n"
"Bist Du Dir absolut sicher, dass Du fortfahren möchtest?"

msgid "Aborted."
msgstr "Abgebrochen."

msgid "Restore of {} triggered. The node will now restart."
msgstr "Der Node wird zur Wiederherstellung von {} neu gestartet."

msgid "Recovery of {} failed. Please check log for details."
msgstr "Wiederherstellung von {} fehlgeschlagen. Für Details, schaue bitte ins Logfile."
