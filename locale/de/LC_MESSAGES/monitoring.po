msgid "Server {server} FPS ({fps}) has been below {min_fps} for more than {period} minutes."
msgstr "Die FPS ({fps}) von Server {server} liegen schon seit mehr als {period} Minuten unter {min_fps}."

msgid "Server Performance Low!"
msgstr "Server-Performance niedrig!"

msgid "Server {server} RAM usage is {ram} GB, exceeding the maximum of {max_ram} GB for more than {period} minutes."
msgstr "Der Speicherverbrauch ({ram} GB) von Server {server} liegt seit mehr als {period} Minuten über dem erlaubten Maximum von {max_ram} GB."

msgid "Excessive RAM consumption!"
msgstr "Hoher Speicherverbrauch!"
