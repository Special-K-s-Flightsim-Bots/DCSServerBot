# /trueskill rating
msgid "Display TrueSkill:tm: ratings"
msgstr "Zeigt TrueSkill:tm:-Ratings"

msgid "TrueSkill:tm: rating: {rating:.2f}."
msgstr "Das TrueSkill:tm:-Rating ist: {rating:.2f}"

# /trueskill history
msgid "Display TrueSkill:tm: history"
msgstr "Zeige TrueSkill:tm:-Historie"

msgid "User {} is not linked."
msgstr "Nutzer {} ist nicht verlinkt."

# /trueskill delete
msgid "Delete TrueSkill:tm: ratings"
msgstr "Lösche TrueSkill:tm: ratings"

msgid "Do you really want to delete TrueSkill:tm: ratings for this user?"
msgstr "Möchtest Du die TrueSkill:tm:-Ratings dieses Nutzers wirklich löschen?"

msgid "Do you really want to delete the TrueSkill:tm: ratings for all users?"
msgstr "Möchtest Du die TrueSkill:tm:-Ratings **aller** Nutzer wirklich löschen?"

msgid "TrueSkill:tm: ratings deleted."
msgstr "TrueSkill:tm:-Ratings gelöscht."

# /trueskill regenerate
msgid "Regenerate TrueSkill:tm: ratings"
msgstr "Regeneriere TrueSkill:tm:-Ratings"

msgid "Do you want to regenerate the TrueSkill:tm: ratings for this user?"
msgstr "Möchtest Du die TrueSkill:tm:-Ratings dieses Nutzers neu erzeugen?"

msgid "Do you really want to regenerate **all** TrueSkill:tm: ratings?"
msgstr "Möchtest Du wirklich **alle** TrueSkill:tm:-Ratings neu erzeugen?"

msgid "Member is not linked to a player."
msgstr "Nutzer ist zu keinem Spieler verlinkt."

msgid "TrueSkill:tm: ratings deleted.\nGenerating new values now ..."
msgstr "TrueSkill:tm:-Ratings wurden gelöscht.\nGeneriere neue Ratings ..."

msgid "TrueSkill:tm: ratings regenerated."
msgstr "TrueSkill:tm:-Ratings regeneriert."

## LISTENER
msgid "Your TrueSkill rating is: {}"
msgstr "Dein TrueSkill-Rating ist: {}"

msgid "You're not allowed to re-join the same match!"
msgstr "Du darfst demselben Match nicht noch einmal beitreten!"

msgid "Player {name} ({rating}) joined the {side} team!"
msgstr "Spieler {name} ({rating}) ist dem Team \"{side}\" beigetreten!"

msgid "The match is on! If you die, crash or leave now, you lose!"
msgstr "Das Spiel beginnt! Wer jetzt stirbt, abstürzt oder das Spiel verlässt, verliert!"

msgid "You won against {loser}! Your new rating is {rating}"
msgstr "Du hast gegen {loser} gewonnen! Dein neues Rating ist {rating}"

msgid "You lost against {winner}! Your new rating is {rating}"
msgstr "Du hast gegen {winner} verloren! Dein neues Rating ist {rating}"

# -skill
msgid "Display your rating"
msgstr "Rating anzeigen"

msgid "The match is over, {} won!\n\n"
"The following players are still alive:\n"
msgstr "Das Spiel ist vorbei, {} hat gewonnen!\n\n"
"Die folgenden Spiele haben überlebt:\n"

msgid "\nThis is the log of your last match:\n"
msgstr "\nDies ist das Log Deines letzten Matches:\n"

msgid "\nYour new rating is as follows:\n"
msgstr "\nEure neuen Ratings sind wie folgt:\n"

# Log
msgid "{killer} in {killer_module} {what} {victim} in {victim_module} with {weapon}"
msgstr "{killer} in {killer_module} hat {victim} in {victim_module} mit {weapon} {what}"

msgid "killed"
msgstr "getötet"

msgid "team-killed"
msgstr "geteam-killed"

msgid "{player} in {module} died ({event})"
msgstr "{player} in {module} ist gestorben ({event})"

msgid "self-kill"
msgstr "Selbstmord"

msgid "crash"
msgstr "Absturz"

msgid "eject"
msgstr "Schleudersitz"

msgid "disconnect"
msgstr "Spiel verlassen"

msgid "change_slot"
msgstr "Spiel verlassen"