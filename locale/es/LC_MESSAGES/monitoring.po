msgid "Server {server} FPS ({fps}) has been below {min_fps} for more than {period} minutes."
msgstr "Los FPS ({fps}) del servidor {server} llevan más de {period} minutos por debajo de {min_fps}."

msgid "Server Performance Low!"
msgstr "¡Rendimiento del servidor bajo!"

msgid "Server {server} RAM usage is {ram} GB, exceeding the maximum of {max_ram} GB for more than {period} minutes."
msgstr "El uso de RAM del servidor {server} es de {ram} GB, superando el máximo de {max_ram} GB durante más de {period} minutos."

msgid "Excessive RAM consumption!"
msgstr "¡Consumo excesivo de RAM!"
